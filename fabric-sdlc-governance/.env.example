# Copy to .env and fill in. Never commit the populated .env.

# --- Microsoft Entra ---
TENANT_ID=00000000-0000-0000-0000-000000000000
SPN_CLIENT_ID=00000000-0000-0000-0000-000000000000
# SPN_CLIENT_SECRET is no longer required when using ADO Workload Identity
# Federation (FIC). Register trust via scripts/register_ado_fic.ps1 and leave
# this blank in CI. Local dev uses 'az login' / DefaultAzureCredential.
SPN_CLIENT_SECRET=

# --- Microsoft Purview ---
PURVIEW_ACCOUNT=naga-purview
PURVIEW_COLLECTION_ID=naga-purview      # root collection id == account name by default

# --- Microsoft Fabric ---
FABRIC_TENANT_ID=${TENANT_ID}
FABRIC_DEV_WS_DE=de-dev
FABRIC_UAT_WS_DE=de-uat
FABRIC_PROD_WS=analytics-prod
FABRIC_CAPACITY_NONPROD=cap-fabric-nonprod
FABRIC_CAPACITY_PROD_BI=cap-fabric-prod-bi

# --- Azure Key Vault (for ADO variable group) ---
KEYVAULT_NAME=kv-naga-fabric-cicd

# --- ADO ---
ADO_ORG=ncheruvu0468
ADO_PROJECT=NagaDevops
